# ===== PostgreSQL =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=asistia_back
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false
DB_POOL_MAX=10

# ===== Microsoft Graph (legacy/local fallback; en produccion viene de tabla companies) =====
# App Registration -> "Certificates & secrets" -> Client secret value
MS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_CLIENT_SECRET=your_client_secret_value

# Mailbox a leer (UPN o email del buzón compartido)
MS_MAILBOX=TI.soporte@grupopettengill.com.py

# Permiso requerido (Application): Mail.Read (admin-consented)

# ===== Google Gemini 3 Flash =====
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview

# ===== Daemon =====
# Cada cuántos segundos se ejecuta el ciclo de lectura
DAEMON_INTERVAL_SECONDS=60

# Carpeta del buzón a leer (Inbox por defecto)
MS_MAIL_FOLDER=inbox

# Cantidad maxima de correos a procesar por empresa en cada ciclo
DAEMON_MAX_EMAILS=20
