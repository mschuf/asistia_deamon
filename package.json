{
  "name": "asistia-daemon",
  "version": "1.0.0",
  "description": "Daemon NestJS que lee correos de Outlook y determina si se debe generar un ticket usando Gemini 3 Flash",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@azure/identity": "^4.5.0",
    "@google/generative-ai": "^0.21.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "dotenv": "^16.4.7",
    "isomorphic-fetch": "^3.0.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/isomorphic-fetch": "^0.0.39",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
